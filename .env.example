# VitalBridge Environment Variables Template
# Copy this file to .env.local and fill in your actual Gemini API Key.
# DO NOT COMMIT .env.local TO GIT.

# Gemini AI API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_api_key_here

# Optional: Set to 'production' for strict mode
NODE_ENV=development
